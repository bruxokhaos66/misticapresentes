# Exemplo de configuracao segura
# Copie este arquivo para o servidor/local e preencha valores reais fora do GitHub.

APP_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=sqlite:./data/mistica.db

# Backup automatico do SQLite em producao
BACKUP_ENABLED=true
BACKUP_HOUR=03
BACKUP_MINUTE=00
BACKUP_KEEP=30
BACKUP_DIRECTORY=/data/backups
BACKUP_TIMEZONE=America/Sao_Paulo

# Segunda camada opcional. Com false, nao carrega boto3/cryptography e nao usa rede.
BACKUP_REMOTE_ENABLED=false
BACKUP_PROVIDER=r2
# Nome do bucket criado no Cloudflare R2.
BACKUP_BUCKET=
# Endpoint S3: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# A regiao do cliente S3 e sempre "auto", conforme exigido pelo R2.
BACKUP_ENDPOINT=
# Credencial R2 com Object Read & Write, restrita somente ao bucket de backup.
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=
# Prefixo opcional dos objetos, por exemplo: mistica/producao
BACKUP_PREFIX=
# Chave AES-256: 32 bytes em base64 ou 64 caracteres hexadecimais.
# Exemplo para gerar hexadecimal: python -c "import secrets; print(secrets.token_hex(32))"
# Guarde uma copia segura fora do Render. Sem esta chave, restaurar e impossivel.
BACKUP_ENCRYPTION_KEY=
BACKUP_UPLOAD_TIMEOUT=30
BACKUP_VERIFY_AFTER_UPLOAD=true
# A aplicacao nao remove objetos remotos. Configure a retencao nas Object
# Lifecycle Rules do bucket R2 (por prefixo, se BACKUP_PREFIX for usado).

# Armazenamento persistente das imagens de produtos enviadas pelo painel
# (backend/product_image_storage.py). O disco dos servicos web do Render e
# efemero fora do disco persistente montado em /data; sem storage remoto
# configurado aqui, as imagens enviadas pelo painel somem no proximo deploy.
# Use um bucket e credenciais PROPRIOS, separados do BACKUP_* acima (escopo e
# prefixo diferentes -- nunca reaproveite a credencial de backup do banco).
PRODUCT_IMAGES_STORAGE_ENABLED=false
PRODUCT_IMAGES_BUCKET=
# Endpoint S3-compativel, ex.: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
PRODUCT_IMAGES_ENDPOINT=
PRODUCT_IMAGES_REGION=auto
# Credencial com Object Read & Write, restrita somente a este bucket/prefixo.
PRODUCT_IMAGES_ACCESS_KEY_ID=
PRODUCT_IMAGES_SECRET_ACCESS_KEY=
# Dominio publico (custom domain ou CDN) que serve o bucket, sem barra final.
PRODUCT_IMAGES_PUBLIC_BASE_URL=
# Prefixo dos objetos dentro do bucket.
PRODUCT_IMAGES_PREFIX=produtos
PRODUCT_IMAGES_UPLOAD_TIMEOUT=15
# So usado quando PRODUCT_IMAGES_STORAGE_ENABLED=false (dev/local ou
# fallback): diretorio local para gravar as imagens. Em producao sem storage
# remoto, aponte para o disco persistente do Render (ex.: /data/uploads/produtos).
PRODUCT_IMAGES_LOCAL_DIR=

# Rota REST de estorno de vendas (POST /api/vendas/{id}/estornar). Desligada
# por padrao: essa rota devolve estoque mas nao reverte o lancamento
# financeiro no caixa original (issue #335 -- a venda nao tem associacao
# confiavel com o caixa_id). So ligue em ambiente controlado, sabendo que
# qualquer estorno feito por ela vai exigir conciliacao manual do caixa.
MISTICA_REST_ESTORNO_ENABLED=false

# Isis 2.0 -- Fase 3 (Estudio Inteligente de Conteudo). Quatro flags
# independentes, todas desligadas por padrao em qualquer ambiente (ver
# backend/isis_content_flags.py). Ligar MISTICA_ISIS_CONTENT_STUDIO_ENABLED
# libera só as rotas administrativas (/api/admin/isis-conteudo/*) para
# revisão manual; a geração diária automática, a geração de imagem e a
# publicação automática têm flags próprias e permanecem desligadas mesmo
# com o estúdio habilitado. MISTICA_ISIS_CONTENT_AUTO_PUBLISH_ENABLED não
# tem nenhum caminho de código implementado nesta fase -- nenhuma rota
# publica em rede social, ligada ou desligada.
MISTICA_ISIS_CONTENT_STUDIO_ENABLED=false
MISTICA_ISIS_CONTENT_AUTO_GENERATION_ENABLED=false
MISTICA_ISIS_CONTENT_IMAGE_GENERATION_ENABLED=false
MISTICA_ISIS_CONTENT_AUTO_PUBLISH_ENABLED=false

# Provedor de IA usado pelo estudio (backend/isis_ai_providers.py). Chave
# nunca exposta ao frontend -- toda geracao ocorre no backend.
OPENAI_API_KEY=
ISIS_CONTENT_OPENAI_TEXT_MODEL=gpt-4o-mini
ISIS_CONTENT_OPENAI_IMAGE_MODEL=gpt-image-1
ISIS_CONTENT_OPENAI_TEXT_CUSTO_ESTIMADO=0.01
ISIS_CONTENT_OPENAI_IMAGE_CUSTO_ESTIMADO=0.08
# Timeout por chamada, tentativas limitadas e orcamento diario (USD) --
# excedido o orcamento, a geracao para e o rascunho fica so com o texto/
# prompt salvo, sem nova chamada de IA.
ISIS_CONTENT_AI_TIMEOUT_SECONDS=20
ISIS_CONTENT_AI_MAX_RETRIES=2
ISIS_CONTENT_AI_DAILY_BUDGET_USD=2.00

# Armazenamento persistente das imagens geradas pelo estudio de conteudo.
# Mesmo padrao de PRODUCT_IMAGES_* acima, mas com bucket/credenciais
# PROPRIOS -- nunca reaproveita PRODUCT_IMAGES_* nem BACKUP_*.
ISIS_CONTENT_IMAGES_STORAGE_ENABLED=false
ISIS_CONTENT_IMAGES_BUCKET=
ISIS_CONTENT_IMAGES_ENDPOINT=
ISIS_CONTENT_IMAGES_REGION=auto
ISIS_CONTENT_IMAGES_ACCESS_KEY_ID=
ISIS_CONTENT_IMAGES_SECRET_ACCESS_KEY=
ISIS_CONTENT_IMAGES_PUBLIC_BASE_URL=
ISIS_CONTENT_IMAGES_PREFIX=isis-conteudo
ISIS_CONTENT_IMAGES_LOCAL_DIR=

# Isis 2.0 -- Chat Inteligente (homologacao controlada, recomendacao de
# produtos e apoio comercial). Independente das quatro flags do Estudio de
# Conteudo acima -- ver backend/isis_chat_flags.py e
# docs/admin/ISIS_CHAT_HOMOLOGACAO.md. Sem MISTICA_ISIS_CHAT_ENABLED e
# MISTICA_ISIS_CHAT_HOMOLOG_ENABLED ligadas, nenhuma conta (nem admin) tem
# acesso as rotas /api/isis2/chat/*. MISTICA_ISIS_CHAT_AI_ENABLED=false
# (default) roda em modo deterministico, sem provedor de IA e custo zero.
MISTICA_ISIS_CHAT_ENABLED=false
MISTICA_ISIS_CHAT_HOMOLOG_ENABLED=false
MISTICA_ISIS_CHAT_AI_ENABLED=false
MISTICA_ISIS_CHAT_PRODUCT_RECOMMENDATIONS_ENABLED=false

MISTICA_ISIS_CHAT_MAX_MESSAGES_PER_SESSION=20
MISTICA_ISIS_CHAT_MAX_SESSIONS_PER_HOUR=5
MISTICA_ISIS_CHAT_MESSAGE_MAX_LENGTH=1000
MISTICA_ISIS_CHAT_SESSION_TTL_MINUTES=60
MISTICA_ISIS_CHAT_DAILY_AI_CALL_LIMIT=0
MISTICA_ISIS_CHAT_DAILY_COST_LIMIT_CENTS=0

STORE_NAME=Mistica Presentes
STORE_WHATSAPP=554999172137
STORE_INSTAGRAM=misticaeso
STORE_DOMAIN=misticaesotericos.com.br

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
IA_PROVIDER=auto

GEMINI_API_KEY=
GROQ_API_KEY=

# Segredos e senhas devem ficar apenas no servidor, nunca no repositorio.
