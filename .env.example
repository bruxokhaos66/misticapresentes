# Exemplo de configuracao segura
# Copie este arquivo para o servidor/local e preencha valores reais fora do GitHub.

APP_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=sqlite:./data/mistica.db

# Backup automatico do SQLite em producao
BACKUP_ENABLED=true
BACKUP_HOUR=03
BACKUP_MINUTE=00
BACKUP_KEEP=30
BACKUP_DIRECTORY=/data/backups
BACKUP_TIMEZONE=America/Sao_Paulo

# Segunda camada opcional. Com false, nao carrega boto3/cryptography e nao usa rede.
BACKUP_REMOTE_ENABLED=false
BACKUP_PROVIDER=r2
# Nome do bucket criado no Cloudflare R2.
BACKUP_BUCKET=
# Endpoint S3: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# A regiao do cliente S3 e sempre "auto", conforme exigido pelo R2.
BACKUP_ENDPOINT=
# Credencial R2 com Object Read & Write, restrita somente ao bucket de backup.
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=
# Prefixo opcional dos objetos, por exemplo: mistica/producao
BACKUP_PREFIX=
# Chave AES-256: 32 bytes em base64 ou 64 caracteres hexadecimais.
# Exemplo para gerar hexadecimal: python -c "import secrets; print(secrets.token_hex(32))"
# Guarde uma copia segura fora do Render. Sem esta chave, restaurar e impossivel.
BACKUP_ENCRYPTION_KEY=
BACKUP_UPLOAD_TIMEOUT=30
BACKUP_VERIFY_AFTER_UPLOAD=true
# A aplicacao nao remove objetos remotos. Configure a retencao nas Object
# Lifecycle Rules do bucket R2 (por prefixo, se BACKUP_PREFIX for usado).

# Armazenamento persistente das imagens de produtos enviadas pelo painel
# (backend/product_image_storage.py). O disco dos servicos web do Render e
# efemero fora do disco persistente montado em /data; sem storage remoto
# configurado aqui, as imagens enviadas pelo painel somem no proximo deploy.
# Use um bucket e credenciais PROPRIOS, separados do BACKUP_* acima (escopo e
# prefixo diferentes -- nunca reaproveite a credencial de backup do banco).
PRODUCT_IMAGES_STORAGE_ENABLED=false
PRODUCT_IMAGES_BUCKET=
# Endpoint S3-compativel, ex.: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
PRODUCT_IMAGES_ENDPOINT=
PRODUCT_IMAGES_REGION=auto
# Credencial com Object Read & Write, restrita somente a este bucket/prefixo.
PRODUCT_IMAGES_ACCESS_KEY_ID=
PRODUCT_IMAGES_SECRET_ACCESS_KEY=
# Dominio publico (custom domain ou CDN) que serve o bucket, sem barra final.
PRODUCT_IMAGES_PUBLIC_BASE_URL=
# Prefixo dos objetos dentro do bucket.
PRODUCT_IMAGES_PREFIX=produtos
PRODUCT_IMAGES_UPLOAD_TIMEOUT=15
# So usado quando PRODUCT_IMAGES_STORAGE_ENABLED=false (dev/local ou
# fallback): diretorio local para gravar as imagens. Em producao sem storage
# remoto, aponte para o disco persistente do Render (ex.: /data/uploads/produtos).
PRODUCT_IMAGES_LOCAL_DIR=

# Rota REST de estorno de vendas (POST /api/vendas/{id}/estornar). Desligada
# por padrao: essa rota devolve estoque mas nao reverte o lancamento
# financeiro no caixa original (issue #335 -- a venda nao tem associacao
# confiavel com o caixa_id). So ligue em ambiente controlado, sabendo que
# qualquer estorno feito por ela vai exigir conciliacao manual do caixa.
MISTICA_REST_ESTORNO_ENABLED=false

# Isis 2.0 -- Fase 3 (Estudio Inteligente de Conteudo). Quatro flags
# independentes, todas desligadas por padrao em qualquer ambiente (ver
# backend/isis_content_flags.py). Ligar MISTICA_ISIS_CONTENT_STUDIO_ENABLED
# libera só as rotas administrativas (/api/admin/isis-conteudo/*) para
# revisão manual; a geração diária automática, a geração de imagem e a
# publicação automática têm flags próprias e permanecem desligadas mesmo
# com o estúdio habilitado. MISTICA_ISIS_CONTENT_AUTO_PUBLISH_ENABLED não
# tem nenhum caminho de código implementado nesta fase -- nenhuma rota
# publica em rede social, ligada ou desligada.
MISTICA_ISIS_CONTENT_STUDIO_ENABLED=false
MISTICA_ISIS_CONTENT_AUTO_GENERATION_ENABLED=false
MISTICA_ISIS_CONTENT_IMAGE_GENERATION_ENABLED=false
MISTICA_ISIS_CONTENT_AUTO_PUBLISH_ENABLED=false

# Provedor de IA usado pelo estudio (backend/isis_ai_providers.py). Chave
# nunca exposta ao frontend -- toda geracao ocorre no backend.
OPENAI_API_KEY=
ISIS_CONTENT_OPENAI_TEXT_MODEL=gpt-4o-mini
ISIS_CONTENT_OPENAI_IMAGE_MODEL=gpt-image-1
ISIS_CONTENT_OPENAI_TEXT_CUSTO_ESTIMADO=0.01
ISIS_CONTENT_OPENAI_IMAGE_CUSTO_ESTIMADO=0.08
# Timeout por chamada, tentativas limitadas e orcamento diario (USD) --
# excedido o orcamento, a geracao para e o rascunho fica so com o texto/
# prompt salvo, sem nova chamada de IA.
ISIS_CONTENT_AI_TIMEOUT_SECONDS=20
ISIS_CONTENT_AI_MAX_RETRIES=2
ISIS_CONTENT_AI_DAILY_BUDGET_USD=2.00

# Armazenamento persistente das imagens geradas pelo estudio de conteudo.
# Mesmo padrao de PRODUCT_IMAGES_* acima, mas com bucket/credenciais
# PROPRIOS -- nunca reaproveita PRODUCT_IMAGES_* nem BACKUP_*.
ISIS_CONTENT_IMAGES_STORAGE_ENABLED=false
ISIS_CONTENT_IMAGES_BUCKET=
ISIS_CONTENT_IMAGES_ENDPOINT=
ISIS_CONTENT_IMAGES_REGION=auto
ISIS_CONTENT_IMAGES_ACCESS_KEY_ID=
ISIS_CONTENT_IMAGES_SECRET_ACCESS_KEY=
ISIS_CONTENT_IMAGES_PUBLIC_BASE_URL=
ISIS_CONTENT_IMAGES_PREFIX=isis-conteudo
ISIS_CONTENT_IMAGES_LOCAL_DIR=

# Isis 2.0 -- Chat Inteligente (homologacao controlada, recomendacao de
# produtos e apoio comercial). Independente das quatro flags do Estudio de
# Conteudo acima -- ver backend/isis_chat_flags.py e
# docs/admin/ISIS_CHAT_HOMOLOGACAO.md. Sem MISTICA_ISIS_CHAT_ENABLED e
# MISTICA_ISIS_CHAT_HOMOLOG_ENABLED ligadas, nenhuma conta (nem admin) tem
# acesso as rotas /api/isis2/chat/*. MISTICA_ISIS_CHAT_AI_ENABLED=false
# (default) roda em modo deterministico, sem provedor de IA e custo zero.
MISTICA_ISIS_CHAT_ENABLED=false
MISTICA_ISIS_CHAT_HOMOLOG_ENABLED=false
MISTICA_ISIS_CHAT_AI_ENABLED=false
MISTICA_ISIS_CHAT_PRODUCT_RECOMMENDATIONS_ENABLED=false

MISTICA_ISIS_CHAT_MAX_MESSAGES_PER_SESSION=20
MISTICA_ISIS_CHAT_MAX_SESSIONS_PER_HOUR=5
MISTICA_ISIS_CHAT_MESSAGE_MAX_LENGTH=1000
MISTICA_ISIS_CHAT_SESSION_TTL_MINUTES=60
MISTICA_ISIS_CHAT_DAILY_AI_CALL_LIMIT=0
MISTICA_ISIS_CHAT_DAILY_COST_LIMIT_CENTS=0

STORE_NAME=Mistica Presentes
STORE_WHATSAPP=554999172137
STORE_INSTAGRAM=misticaeso
STORE_DOMAIN=misticaesotericos.com.br

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
IA_PROVIDER=auto

GEMINI_API_KEY=
GROQ_API_KEY=

# Mercado Pago -- pagamento com cartao de credito (backend/mercadopago_*.py).
# O Pix atual (backend/pix.py) e manual e continua funcionando de forma
# totalmente independente destas variaveis -- nao e afetado por elas.
#
# MERCADO_PAGO_ENABLED=false mantem o cartao indisponivel de forma elegante:
# o site continua funcionando normalmente (Pix, carrinho, catalogo), a opcao
# de cartao simplesmente nao aparece no checkout e o endpoint publico de
# config responde "enabled": false. So ligue depois de configurar as
# credenciais abaixo em um ambiente controlado (sandbox antes de producao).
MERCADO_PAGO_ENABLED=false
# production ou sandbox. Use sandbox apenas para testes manuais controlados,
# nunca em producao real.
MERCADO_PAGO_ENVIRONMENT=production
# Public Key -- pode ser exposta ao navegador (necessaria para a
# tokenizacao do cartao pelo SDK oficial do Mercado Pago no frontend).
MERCADO_PAGO_PUBLIC_KEY=
# Access Token -- NUNCA exponha ao navegador, a logs, commits ou respostas
# de API. Uso exclusivo do backend para criar/consultar pagamentos
# server-to-server na API do Mercado Pago.
MERCADO_PAGO_ACCESS_TOKEN=
# Segredo usado para validar a assinatura (x-signature) das notificacoes de
# webhook do Mercado Pago (POST /api/webhooks/pagamentos/mercadopago).
# Copie o valor gerado no painel do Mercado Pago (Suas integracoes >
# Webhooks > Chave secreta) apos cadastrar a URL do webhook.
MERCADO_PAGO_WEBHOOK_SECRET=
# Opcional -- texto exibido na fatura do cartao do comprador (campo
# statement_descriptor da Payments API). Puramente informativo: nunca afeta
# aprovacao/recusa, regra comercial ou o fluxo de checkout. Vazio = campo
# nunca enviado (comportamento atual preservado). Truncado a 13 caracteres.
MERCADO_PAGO_STATEMENT_DESCRIPTOR=

# Notificacoes administrativas por WhatsApp (WhatsApp Business Platform /
# Cloud API oficial da Meta -- ver backend/whatsapp_*.py e
# docs/admin/WHATSAPP_NOTIFICACOES.md). Nao usa WhatsApp Web, Selenium,
# navegador controlado, link wa.me nem API nao-oficial.
#
# WHATSAPP_NOTIFICATIONS_ENABLED=false mantem o recurso completamente
# desligado por padrao (inclusive em producao): nenhuma chamada de rede e
# feita, nenhum worker roda, pedidos/pagamentos/webhooks do Mercado Pago
# continuam funcionando exatamente como antes. So ligue depois de concluir
# a configuracao completa abaixo (ver checklist no documento citado acima).
WHATSAPP_NOTIFICATIONS_ENABLED=false
# Unico provider real suportado hoje: meta_cloud. "disabled" forca o
# provider nulo mesmo com a flag acima ligada (util para ambiente de teste).
WHATSAPP_PROVIDER=meta_cloud
# Versao da Graph API -- CONFIRME a versao atualmente recomendada na
# documentacao oficial da Meta antes de ativar em producao (a Meta
# descontinua versoes antigas periodicamente). Deixe em branco para usar o
# padrao definido em backend/whatsapp_flags.py (revise antes de usar).
WHATSAPP_GRAPH_API_VERSION=
# IDs do numero e da conta comercial (WhatsApp Business Account), obtidos no
# painel da Meta (Meta for Developers > seu app > WhatsApp > Configuracao da API).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Access Token -- System User Token de longa duracao (nunca o token de
# usuario de teste de 24h em producao). Uso exclusivo do backend, nunca
# exposto ao navegador, a logs ou a respostas de API.
WHATSAPP_ACCESS_TOKEN=
# App Secret -- usado apenas para validar a assinatura (X-Hub-Signature-256)
# dos callbacks de status recebidos em POST /api/webhooks/whatsapp.
WHATSAPP_APP_SECRET=
# Verify Token -- string arbitraria escolhida por voce, usada apenas na
# verificacao inicial do webhook (GET /api/webhooks/whatsapp, hub.verify_token)
# no painel da Meta. Nunca e exposta em nenhuma resposta HTTP.
WHATSAPP_VERIFY_TOKEN=
# Numeros administrativos autorizados a receber as notificacoes, separados
# por virgula (formato livre aceito -- normalizado automaticamente para o
# padrao E.164 sem "+"; numeros com 10-11 digitos recebem o codigo do pais
# abaixo). NUNCA inclua telefone de cliente aqui -- essa lista e so para a
# equipe/administracao da loja.
# Exemplo: WHATSAPP_ADMIN_RECIPIENTS=5511999998888,5511977776666
WHATSAPP_ADMIN_RECIPIENTS=
WHATSAPP_DEFAULT_COUNTRY_CODE=55
WHATSAPP_REQUEST_TIMEOUT_SECONDS=10
WHATSAPP_MAX_RETRIES=5
WHATSAPP_RETRY_BASE_SECONDS=60
# Legado da WhatsApp Business API On-Premise -- normalmente deixe em branco;
# a Cloud API atual endereca templates por nome + idioma, sem namespace.
WHATSAPP_TEMPLATE_NAMESPACE=
WHATSAPP_TEMPLATE_LANGUAGE=pt_BR
# Nome de cada template, EXATAMENTE como cadastrado e APROVADO no painel da
# Meta (Gerenciador do WhatsApp > Modelos de mensagem). Sem o nome correto
# aqui, o envio falha de forma permanente (nunca envia texto livre como
# substituto) -- ver docs/admin/WHATSAPP_NOTIFICACOES.md para o texto
# sugerido de cada template.
WHATSAPP_TEMPLATE_ADMIN_NOVO_PEDIDO=admin_novo_pedido
WHATSAPP_TEMPLATE_ADMIN_PIX_GERADO=admin_pix_gerado
WHATSAPP_TEMPLATE_ADMIN_PAGAMENTO_APROVADO=admin_pagamento_aprovado
WHATSAPP_TEMPLATE_ADMIN_PAGAMENTO_PENDENTE=admin_pagamento_pendente
WHATSAPP_TEMPLATE_ADMIN_PAGAMENTO_RECUSADO=admin_pagamento_recusado
WHATSAPP_TEMPLATE_ADMIN_PAGAMENTO_EXPIRADO=admin_pagamento_expirado
WHATSAPP_TEMPLATE_ADMIN_PAGAMENTO_CANCELADO=admin_pagamento_cancelado
WHATSAPP_TEMPLATE_ADMIN_PAGAMENTO_REEMBOLSADO=admin_pagamento_reembolsado
WHATSAPP_TEMPLATE_ADMIN_CHARGEBACK=admin_chargeback
WHATSAPP_TEMPLATE_ADMIN_FALHA_RECONCILIACAO=admin_falha_reconciliacao
# URL HTTPS do login administrativo (opcional, sem token/query string) --
# reservado para uso futuro em variaveis de template que aceitem link.
WHATSAPP_ADMIN_PAINEL_URL=

# Segredos e senhas devem ficar apenas no servidor, nunca no repositorio.
