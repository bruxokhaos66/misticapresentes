# Exemplo de configuracao segura
# Copie este arquivo para o servidor/local e preencha valores reais fora do GitHub.

APP_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=sqlite:./data/mistica.db

# Backup automatico do SQLite em producao
BACKUP_ENABLED=true
BACKUP_HOUR=03
BACKUP_MINUTE=00
BACKUP_KEEP=30
BACKUP_DIRECTORY=/data/backups
BACKUP_TIMEZONE=America/Sao_Paulo

# Segunda camada opcional. Com false, nao carrega boto3/cryptography e nao usa rede.
BACKUP_REMOTE_ENABLED=false
BACKUP_PROVIDER=r2
# Nome do bucket criado no Cloudflare R2.
BACKUP_BUCKET=
# Endpoint S3: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# A regiao do cliente S3 e sempre "auto", conforme exigido pelo R2.
BACKUP_ENDPOINT=
# Credencial R2 com Object Read & Write, restrita somente ao bucket de backup.
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=
# Prefixo opcional dos objetos, por exemplo: mistica/producao
BACKUP_PREFIX=
# Chave AES-256: 32 bytes em base64 ou 64 caracteres hexadecimais.
# Exemplo para gerar hexadecimal: python -c "import secrets; print(secrets.token_hex(32))"
# Guarde uma copia segura fora do Render. Sem esta chave, restaurar e impossivel.
BACKUP_ENCRYPTION_KEY=
BACKUP_UPLOAD_TIMEOUT=30
BACKUP_VERIFY_AFTER_UPLOAD=true
# A aplicacao nao remove objetos remotos. Configure a retencao nas Object
# Lifecycle Rules do bucket R2 (por prefixo, se BACKUP_PREFIX for usado).

# Armazenamento persistente das imagens de produtos enviadas pelo painel
# (backend/product_image_storage.py). O disco dos servicos web do Render e
# efemero fora do disco persistente montado em /data; sem storage remoto
# configurado aqui, as imagens enviadas pelo painel somem no proximo deploy.
# Use um bucket e credenciais PROPRIOS, separados do BACKUP_* acima (escopo e
# prefixo diferentes -- nunca reaproveite a credencial de backup do banco).
PRODUCT_IMAGES_STORAGE_ENABLED=false
PRODUCT_IMAGES_BUCKET=
# Endpoint S3-compativel, ex.: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
PRODUCT_IMAGES_ENDPOINT=
PRODUCT_IMAGES_REGION=auto
# Credencial com Object Read & Write, restrita somente a este bucket/prefixo.
PRODUCT_IMAGES_ACCESS_KEY_ID=
PRODUCT_IMAGES_SECRET_ACCESS_KEY=
# Dominio publico (custom domain ou CDN) que serve o bucket, sem barra final.
PRODUCT_IMAGES_PUBLIC_BASE_URL=
# Prefixo dos objetos dentro do bucket.
PRODUCT_IMAGES_PREFIX=produtos
PRODUCT_IMAGES_UPLOAD_TIMEOUT=15
# So usado quando PRODUCT_IMAGES_STORAGE_ENABLED=false (dev/local ou
# fallback): diretorio local para gravar as imagens. Em producao sem storage
# remoto, aponte para o disco persistente do Render (ex.: /data/uploads/produtos).
PRODUCT_IMAGES_LOCAL_DIR=

# Rota REST de estorno de vendas (POST /api/vendas/{id}/estornar). Desligada
# por padrao: essa rota devolve estoque mas nao reverte o lancamento
# financeiro no caixa original (issue #335 -- a venda nao tem associacao
# confiavel com o caixa_id). So ligue em ambiente controlado, sabendo que
# qualquer estorno feito por ela vai exigir conciliacao manual do caixa.
MISTICA_REST_ESTORNO_ENABLED=false

STORE_NAME=Mistica Presentes
STORE_WHATSAPP=554999172137
STORE_INSTAGRAM=misticaeso
STORE_DOMAIN=misticaesotericos.com.br

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
IA_PROVIDER=auto

GEMINI_API_KEY=
GROQ_API_KEY=

# Segredos e senhas devem ficar apenas no servidor, nunca no repositorio.
