<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Central de Atendimento (PR #413): câmera para foto e microfone para
         áudio, ambos pedidos em runtime só quando o atendente toca no botão
         correspondente no compositor (nunca no início do app). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Não obrigatório: dispositivos sem câmera continuam podendo instalar o app. -->
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:name=".app.MisticaApplication"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="${networkSecurityConfig}"
        android:usesCleartextTraffic="false"
        android:icon="@drawable/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".legacy.LegacyPanelActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <!-- MisticaApplication implementa Configuration.Provider (PR #414,
             WorkManager com WorkerFactory própria); o initializer padrão
             via androidx.startup precisa ser removido para a inicialização
             sob demanda funcionar (ver AttendanceWorkerFactory). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
